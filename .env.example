# AI Product Factory — environment placeholders
# Copy to .env and fill values when needed.
# Never commit real secrets.

NODE_ENV=development
PORT=3000

# Image provider for `npm run generate` (Milestone M10)
# fake  — FakeImageProvider (no network; default)
# openai — OpenAIImageProvider (requires OPENAI_API_KEY)
IMAGE_PROVIDER=fake

# Required when IMAGE_PROVIDER=openai
OPENAI_API_KEY=

# Optional OpenAI settings
OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=60000
# OPENAI_RETRIES=1

# Future: ResearchProvider / TextProvider / Marketplace / Storage
# RESEARCH_PROVIDER=
# TEXT_PROVIDER_API_KEY=
# MARKETPLACE_API_KEY=
# STORAGE_PATH=./.data
