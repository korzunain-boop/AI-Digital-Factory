{
  "name": "@ai-product-factory/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./composition": {
      "types": "./dist/bootstrap/composition-root.d.ts",
      "import": "./dist/bootstrap/composition-root.js"
    },
    "./config": {
      "types": "./dist/config/runtime-config.d.ts",
      "import": "./dist/config/runtime-config.js"
    },
    "./bundle": {
      "types": "./dist/bundle/index.d.ts",
      "import": "./dist/bundle/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "generate": "node dist/cli/generate.js",
    "generate-bundle": "node dist/cli/generate-bundle.js",
    "generate-posters": "node dist/cli/generate-posters.js",
    "generate-metadata": "node dist/cli/generate-metadata.js"
  },
  "dependencies": {
    "@ai-product-factory/application": "*",
    "@ai-product-factory/domain": "*",
    "@ai-product-factory/infrastructure": "*",
    "@ai-product-factory/shared": "*"
  }
}
